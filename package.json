{
  "name": "applypilot-ai",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:watch": "vitest",
    "worker:dev": "tsx watch worker/index.ts",
    "worker:start": "tsx worker/index.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.1089.0",
    "@prisma/client": "6.2.1",
    "dotenv": "16.4.7",
    "ioredis": "5.4.2",
    "next": "15.5.20",
    "pino": "9.6.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.2.0",
    "@eslint/js": "9.18.0",
    "@types/node": "22.20.1",
    "@types/react": "19.0.7",
    "@types/react-dom": "19.0.3",
    "autoprefixer": "10.4.20",
    "eslint": "9.39.5",
    "eslint-config-next": "15.5.20",
    "eslint-config-prettier": "9.1.0",
    "pino-pretty": "13.0.0",
    "postcss": "8.5.10",
    "prettier": "3.4.2",
    "prisma": "6.2.1",
    "tailwindcss": "3.4.17",
    "tsx": "4.23.1",
    "typescript": "5.7.3",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.10"
  },
  "overrides": {
    "vite": "8.1.5",
    "esbuild": "0.28.1"
  }
}
