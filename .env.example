# ApplyPilot AI — environment variables (validated by src/lib/env.ts).
# Copy to .env for local development; values below match docker-compose.yml.
# NEVER commit .env.

# development | test | production
NODE_ENV=development

# Public URL the app is served from; the CSRF Origin allowlist derives from it.
APP_URL=http://localhost:3000

# PostgreSQL (system of record + transactional outbox)
DATABASE_URL=postgresql://applypilot:applypilot@localhost:5432/applypilot

# Redis (BullMQ + rate limiting)
REDIS_URL=redis://localhost:6379

# S3-compatible object storage (MinIO locally; R2/S3/Supabase in production)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=applypilot-dev
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
# 1 for MinIO (path-style addressing); 0 for AWS S3 / R2
S3_FORCE_PATH_STYLE=1

# pino log level: fatal | error | warn | info | debug | trace | silent
LOG_LEVEL=info

# Enables the test-only auth provider for E2E runs (M1). Startup FAILS if this
# is 1 while NODE_ENV=production (kill switch in src/lib/env.ts). Leave unset
# outside E2E runs.
# E2E_TEST_MODE=1
