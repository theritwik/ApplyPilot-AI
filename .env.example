# Copy this file to .env for local development (docker-compose defaults match below).

# Environment
NODE_ENV=development

# Enables a test-only auth bypass for Playwright E2E runs (wired up in M1).
# NEVER set this in production: startup fails hard if NODE_ENV=production and
# E2E_TEST_MODE=1 (see src/lib/env.ts).
E2E_TEST_MODE=0

# Base URL of this app. Used to build the CSRF Origin/Host allowlist.
APP_URL=http://localhost:3000

# PostgreSQL (see docker-compose.yml for local defaults)
DATABASE_URL=postgresql://applypilot:applypilot@localhost:5432/applypilot?schema=public

# Redis (BullMQ + rate limiting; BullMQ itself is wired up starting in M2)
REDIS_URL=redis://localhost:6379

# S3-compatible object storage (MinIO locally; Cloudflare R2 / AWS S3 / Supabase
# Storage in production)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=applypilot-dev
S3_ACCESS_KEY_ID=applypilot
S3_SECRET_ACCESS_KEY=applypilot-secret
S3_FORCE_PATH_STYLE=true

# Logging
LOG_LEVEL=info
