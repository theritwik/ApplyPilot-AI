# ApplyPilot AI — environment template. Copy to .env and adjust.
# Values below match docker-compose.yml local-dev services; they are NOT
# production credentials. Never commit a real .env.

# ── Application ──────────────────────────────────────────────────────────────
NODE_ENV=development
# Public origin of the app; the CSRF Origin allowlist derives from it.
APP_URL=http://localhost:3000
# pino level: fatal | error | warn | info | debug | trace
LOG_LEVEL=info
# Test-only auth provider switch (used from M1). Must NEVER be "1" in
# production — the app refuses to start (see src/lib/env.ts kill switch).
# E2E_TEST_MODE=0

# ── PostgreSQL ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://applypilot:applypilot@localhost:5432/applypilot

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── S3-compatible object storage ─────────────────────────────────────────────
# Local dev: MinIO from docker-compose. Production: Cloudflare R2 / AWS S3 /
# Supabase Storage — set the provider's endpoint, region, bucket, and keys.
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=applypilot-dev
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
# "true" required for MinIO (and some S3-compatible providers)
S3_FORCE_PATH_STYLE=true
